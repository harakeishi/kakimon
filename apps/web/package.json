{
  "name": "@kakimon/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync-assets": "node scripts/sync-kakitori-data.mjs && node scripts/sync-emoji.mjs",
    "predev": "pnpm sync-assets",
    "dev": "vite",
    "prebuild": "pnpm sync-assets",
